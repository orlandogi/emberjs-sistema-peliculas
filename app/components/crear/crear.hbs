<button type="button"  class="btn btn-primary mb-3 mt-4" data-bs-toggle="modal" data-bs-target="#exampleModal" {{on "click" this.validarBoton}}>Agregar
    {{@button}}</button>

<div class="modal fade" id="exampleModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
    aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog p-4 m-0 m-auto">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Datos {{@title}}</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form class="was-validated">
                    <div class="mb-3">
                        <label for="recipient-name" class="col-form-label">Nombre:</label>
                        <div class="pe-5"><input type="text" aria-describedby="usernameBlock" class="form-control" id="recipient-name" value={{this.strNombreUsuario}}  placeholder="Digite el nombre del usuario" />
                        </div>
                         <div id="usernameBlock" class="form-text mb-3">
                        Solo se admiten numeros y letras <br>
                        Debe tener al menos 6 caracteres</div>
                        
                    </div>

                    {{#if @user}}
                    <label for="inputPassword5" class="form-label">Password</label>
                    <div class="pe-5"><input type="password" id="inputPassword5" class="form-control"
                        aria-describedby="passwordHelpBlock" value={{this.strContraseña}}  placeholder="Digite la contraseña"></div>
                    <div id="passwordHelpBlock" class="form-text mb-3">
                        Tu contraseña debe tener 8-20 caracteres <br>
                        Al menos una letra minuscula (a - z) <br>
                        Al menos un valor numério (0 - 9) <br>
                        Al menos un símbolo especial (!@#$%^*=+-_)
                        </div>
                    <div class="wrappeer todos ">
                        <label for="formFile" class="form-label">Tipo de usuario: </label>
                        <input class="todos" type="radio" name="select2" id="option-3" checked value="1">
                        <input class="todos" type="radio" name="select2" id="option-4" value="2">
                        <label for="option-3" class="optionn option-3 todos">
                            <div class="dott todos"></div>
                            <span class="spann todos">Normal</span>
                        </label>
                        <label for="option-4" class="optionn option-4 todos">
                            <div class="dott todos"></div>
                            <span class="spann todos">Administrador</span>
                        </label>

                    </div>
                    <div class="form-text mb-3" id="descripci">
<b>*Tiene acceso limitado al sistema*</b>                    
</div>
                    {{else}}
                    <div class="mb-3">
                        <label for="exampleFormControlTextarea1" class="form-label">Sinopsis</label>
                        <textarea class="form-control tamaño" id="exampleFormControlTextarea1" rows="3" required></textarea>
                    <div class="invalid-feedback">
                    Please enter a message in the textarea.
                        </div>
                   
                    </div>
                    <div class="row g-3 align-items-center mb-3">
                        <div class="col-auto">
                            <label for="number" class="col-form-label">Duracion</label>
                        </div>
                        <div class="col-auto">
                            <input id="number" type="number" class="form-control" aria-describedby="duracion" />
                        </div>
                        <div class="col-auto">
                            <span id="duracion" class="form-text">
                                Minutos
                            </span>
                        </div>
                    </div>
                    <div class="row g-3 align-items-center mb-3">
                        <div class="col-auto">
                            <label for="number2" class="col-form-label">Precio:</label>
                        </div>
                        <div class="col-auto d-flex">
                            <span class="input-group-text">$</span>
                            <input id="number2" type="number" class="form-control" aria-describedby="precio" />
                            <span class="input-group-text">$</span>

                        </div>
                        <div class="col-auto">
                            <span id="precio" class="form-text">
                                MX
                            </span>
                        </div>
                    </div>

                    <div class="formulario-div mb-3">
                        <label for="formFile" class="form-label">Imagen</label>
                        <img class="formulario-img"
                            src="https://static-00.iconduck.com/assets.00/user-icon-1024x1024-dtzturco.png" alt="avatar"
                            id="img" />
                        <input type="file" name="foto" id="foto" accept="image/*" />
                        <label for="foto">Cambiar foto</label>
                    </div>

                    <div class="btn-group dropup mb-3">
                        <label for="formFile" class="form-label">Generos: </label>
                        <button type="button" class="btn btn-secondary dropdown-toggle" data-bs-toggle="dropdown"
                            aria-expanded="false">
                            Selecciona una opción
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#" onclick="selectOption('Manzana')">Manzana</a></li>
                            <li><a class="dropdown-item" href="#" onclick="selectOption('Banana')">Banana</a></li>
                            <li><a class="dropdown-item" href="#" onclick="selectOption('Naranja')">Naranja</a></li>
                            <li><a class="dropdown-item" href="#" onclick="selectOption('Uva')">Uva</a></li>
                        </ul>
                    </div>
                    <div class="etiqueta-container" id="tagContainer"></div>

                    {{/if}}

                    <div class="wrappeer todos mb-3">
                        <label for="formFile" class="form-label">Estado: </label>
                        <input class="todos" type="radio" name="select" id="option-1" checked value="1">
                        <input class="todos" type="radio" name="select" id="option-2" value="2">
                        <label for="option-1" class="optionn option-1 todos">
                            <div class="dott todos"></div>
                            <span class="spann todos">{{@state1}}</span>
                        </label>
                        <label for="option-2" class="optionn option-2 todos">
                            <div class="dott todos"></div>
                            <span class="spann todos">{{@state2}}</span>
                        </label>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                        <button type="submit" class="btn btn-success" {{on "click" this.insertUser}}>{{@send}}</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>


<script>

const axios = require('axios');

async function obtenerDescripcion() {
  try {
    const respuesta = await fetch('http://localhost:3000/api/tipoUsuario');
    const datos = await respuesta.json();
    return datos;
  } catch (error) {
  }
}
const respuesta = obtenerDescripcion();

const normalRadio = document.getElementById("option-3");
const administradorRadio = document.getElementById("option-4");


function verificarOpcionInicial() {
    if (normalRadio.checked) {
       document.getElementById("descripci").innerHTML='<b>*Tiene acceso limitado al sistema*</b>';    
    } 
}

window.addEventListener("load", verificarOpcionInicial);

 normalRadio.addEventListener("change", function() {
    if (normalRadio.checked) {
       document.getElementById("descripci").innerHTML='<b>*Tiene acceso limitado al sistema*</b>';

    
    }
});

administradorRadio.addEventListener("change", function() {
    if (administradorRadio.checked) {
        
       document.getElementById("descripci").innerHTML='<b>*Tiene control total del sistema*</b>';
    }
});

    const defaultFile = 'https://static-00.iconduck.com/assets.00/user-icon-1024x1024-dtzturco.png';
    const file = document.getElementById('foto');
    const img = document.getElementById('img');
    file.addEventListener('change', e => {
        if (e.target.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                img.src = e.target.result;
            }
            reader.readAsDataURL(e.target.files[0])
        } else {
            img.src = defaultFile;
        }
    });


    function selectOption(option) {
        const tagContainer = document.getElementById('tagContainer');

        // Crear una nueva etiqueta
        const tag = document.createElement('div');
        tag.classList.add('etiqueta');
        tag.textContent = option;

        // Crear el botón de cierre
        const closeButton = document.createElement('span');
        closeButton.classList.add('etiqueta-close');
        closeButton.textContent = 'x';
        closeButton.addEventListener('click', function () {
            tag.remove();
        });

        // Adjuntar el botón de cierre a la etiqueta
        tag.appendChild(closeButton);

        // Agregar la etiqueta al contenedor
        tagContainer.appendChild(tag);
    }
</script>